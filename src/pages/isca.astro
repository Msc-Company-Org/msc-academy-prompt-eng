---
import Base from '../layouts/Base.astro';
const desc = 'Baixe grátis o Kit Prompt Engineering MSC: 30 prompts-modelo por profissão + a régua C.L.A.R.O. + mini-aula de 12 min. O método que eu uso nos meus sistemas de IA em produção.';
---
<Base title="Kit Prompt Engineering MSC (grátis) — 30 prompts + a régua C.L.A.R.O." description={desc} canonical="https://academy.msccompany.com.br/isca">
  <section class="bg-glow">
    <div class="mx-auto grid max-w-5xl items-center gap-10 px-4 py-16 md:grid-cols-2">
      <div>
        <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-brand-400">Material gratuito</p>
        <h1 class="text-balance text-3xl font-black leading-tight sm:text-4xl">
          30 prompts que <span class="gradient-text">entregam</span> na 1ª tentativa — + a régua que eu uso nos meus sistemas de IA
        </h1>
        <p class="mt-4 text-lg text-zinc-300">Baixe o <strong>Kit Prompt Engineering MSC</strong>: 30 prompts-modelo organizados por profissão, a <strong>régua C.L.A.R.O.</strong> (1 página) e uma mini-aula de 12 min onde eu transformo um prompt ruim num que entrega — ao vivo.</p>
        <ul class="mt-6 space-y-2 text-zinc-300">
          <li>✅ 30 prompts prontos pra copiar, colar e adaptar</li>
          <li>✅ A régua C.L.A.R.O. — o método por trás de todo prompt profissional</li>
          <li>✅ Mini-aula real (sem teoria de blog gringo)</li>
        </ul>
      </div>

      <div class="rounded-2xl border border-white/10 bg-ink-800/60 p-6 shadow-2xl shadow-black/40">
        <h2 class="text-lg font-bold text-zinc-100">Receba agora, de graça</h2>
        <form id="optin" class="mt-4 space-y-3">
          <input name="name" type="text" autocomplete="name" placeholder="Seu nome" required
            class="w-full rounded-lg border border-white/10 bg-ink-900 px-4 py-3 text-zinc-100 placeholder:text-zinc-500 focus:border-brand-500 focus:outline-none" />
          <input name="email" type="email" autocomplete="email" placeholder="Seu melhor e-mail" required
            class="w-full rounded-lg border border-white/10 bg-ink-900 px-4 py-3 text-zinc-100 placeholder:text-zinc-500 focus:border-brand-500 focus:outline-none" />
          <input name="phone" type="tel" autocomplete="tel" placeholder="WhatsApp (com DDD)" required
            class="w-full rounded-lg border border-white/10 bg-ink-900 px-4 py-3 text-zinc-100 placeholder:text-zinc-500 focus:border-brand-500 focus:outline-none" />
          <select name="profissao" required
            class="w-full rounded-lg border border-white/10 bg-ink-900 px-4 py-3 text-zinc-300 focus:border-brand-500 focus:outline-none">
            <option value="">Sua área…</option>
            <option>Vendas / Comercial</option>
            <option>Atendimento / Suporte</option>
            <option>Conteúdo / Social Media</option>
            <option>Escritório / Administrativo</option>
            <option>Freelancer / Serviços</option>
            <option>Estudo / Concurso / Carreira</option>
            <option>Outra</option>
          </select>
          <button type="submit" class="w-full rounded-xl bg-brand-500 py-3.5 font-extrabold text-ink-950 transition hover:bg-brand-400">
            QUERO O KIT GRÁTIS →
          </button>
          <p id="optin-msg" class="hidden text-center text-sm"></p>
          <p class="text-center text-xs text-zinc-500">Sem spam. Você pode sair quando quiser.</p>
        </form>
      </div>
    </div>
  </section>

  <script>
    import { track, uuid, getAttribution, getGaClientId } from '../lib/tracking';
    const form = document.getElementById('optin') as HTMLFormElement | null;
    const msg = document.getElementById('optin-msg');
    let started = false;
    form?.addEventListener('focusin', () => {
      if (!started) { started = true; track('form_start', { form_id: 'optin_isca' }); }
    });
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form);
      const event_id = uuid();
      const payload = {
        name: fd.get('name'), email: fd.get('email'), phone: fd.get('phone'), profissao: fd.get('profissao'),
        event_id, client_id: getGaClientId(), attribution: getAttribution(),
        fbp: document.cookie.match(/_fbp=([^;]+)/)?.[1],
        fbc: document.cookie.match(/_fbc=([^;]+)/)?.[1],
      };
      try {
        await fetch('/api/lead', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      } catch { /* segue mesmo se a API falhar */ }
      track('generate_lead', { value: 5, currency: 'BRL', lead_source: 'isca', form_id: 'optin_isca', method: 'email', event_id });
      if (msg) { msg.textContent = 'Pronto! Enviamos o kit pro seu e-mail e WhatsApp. 🎉'; msg.classList.remove('hidden'); msg.classList.add('text-brand-400'); }
      setTimeout(() => { location.href = '/?utm_source=isca&utm_medium=optin'; }, 1400);
    });
  </script>
</Base>
