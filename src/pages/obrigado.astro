---
import Base from '../layouts/Base.astro';
---
<Base title="Obrigado! — MSC Academy" noindex={true} canonical="https://academy.msccompany.com.br/obrigado">
  <section class="mx-auto grid min-h-[70vh] max-w-xl place-items-center px-5 text-center">
    <div>
      <svg viewBox="0 0 24 24" class="mx-auto h-14 w-14 text-sage" fill="none" stroke="currentColor" stroke-width="1.4"><circle cx="12" cy="12" r="10"/><path d="M8 12l3 3 5-6"/></svg>
      <h1 class="mt-5 font-display text-3xl font-extrabold sm:text-4xl">Compra confirmada. Bem-vindo!</h1>
      <p class="mt-4 text-lg text-ink/80">Seu acesso ao <strong class="text-ink">Arsenal de IA</strong> foi liberado. Verifique seu e-mail e WhatsApp — enviamos o link da área de membros.</p>
      <p class="mt-2 text-sm text-ink/55">Não chegou em 5 min? Olhe o spam ou fale com a gente.</p>
      <a href="/" class="btn-ghost mt-8">Voltar ao início</a>
    </div>
  </section>

  <script>
    import { track } from '../lib/tracking';
    const sp = new URLSearchParams(location.search);
    const orderId = sp.get('order_id') || sp.get('transaction_id');
    const value = Number(sp.get('amount') || sp.get('value') || 97);
    if (orderId) {
      track('purchase', {
        transaction_id: orderId, value, currency: 'BRL', event_id: orderId,
        items: [{ item_id: 'curso-prompt-97', item_name: 'Prompt Profissional', price: value, quantity: 1 }],
      });
    }
  </script>
</Base>
