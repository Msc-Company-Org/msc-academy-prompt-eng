---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
  product?: boolean; // renderiza o schema Product (só na carta de vendas)
}

const {
  title = 'Arsenal de IA — templates, skills e superpowers que eu rodo em produção | MSC Academy',
  description = 'O arsenal de IA que eu uso em produção: templates, fluxos, hooks e superpowers, do básico ao avançado, + o Método P.R.O.© pra adaptar tudo. R$97, acesso vitalício, garantia de 7 dias.',
  canonical = 'https://arsenal.msc-academy.com.br/',
  noindex = false,
  product = false,
} = Astro.props;
const OG_IMAGE = 'https://arsenal.msc-academy.com.br/og.jpg';

// Container real do Moisés como padrão (sobrescrevível por env PUBLIC_GTM_ID no Vercel)
const GTM_ID = import.meta.env.PUBLIC_GTM_ID || 'GTM-P4P7R35C';
const FB_PIXEL_ID = import.meta.env.PUBLIC_FB_PIXEL_ID || '';
// GA4 real do projeto (default; sobrescrevível por env PUBLIC_GA_ID)
const GA_ID = import.meta.env.PUBLIC_GA_ID || 'G-C2HZX6SQ9Q';
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Favicon / ícones -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#163300" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={OG_IMAGE} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Arsenal de IA — 7 peças grátis" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    <!-- Fonts: Fraunces (display serifado, editorial) + Inter (texto/UI) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,600;9..144,700;9..144,800;9..144,900&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- 1) Consent Mode v2 default = denied (roda ANTES de qualquer tag) -->
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){ dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('consent', 'default', {
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
        analytics_storage: 'denied',
        functionality_storage: 'granted',
        security_storage: 'granted',
        wait_for_update: 500,
      });
    </script>

    <!-- 2) Google Tag Manager (gerencia GA4 + Ads + Meta lá dentro) -->
    {GTM_ID && (
      <script is:inline set:html={`(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','${GTM_ID}');`} />
    )}

    <!-- 2b) GA4 direto (gtag.js). Se você configurar a tag GA4 DENTRO do GTM, remova este bloco pra não duplicar page_view. -->
    {GA_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}></script>
        <script is:inline set:html={`window.gtag=window.gtag||function(){dataLayer.push(arguments);};gtag('js', new Date());gtag('config', '${GA_ID}');`} />
      </>
    )}

    <!-- 2c) Meta Pixel base (eventos só após consentimento, disparados via dataLayer/GTM) -->
    {FB_PIXEL_ID && (
      <script is:inline set:html={`!function(f,b,e,v,n,t,s){if(f.fbq)return;n=f.fbq=function(){n.callMethod?n.callMethod.apply(n,arguments):n.queue.push(arguments)};if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';n.queue=[];t=b.createElement(e);t.async=!0;t.src=v;s=b.getElementsByTagName(e)[0];s.parentNode.insertBefore(t,s)}(window,document,'script','https://connect.facebook.net/en_US/fbevents.js');fbq('init','${FB_PIXEL_ID}');fbq('track','PageView');`} />
    )}

    <!-- Schema.org: Product — SÓ na carta de vendas (não na landing grátis) -->
    {product && (
      <script type="application/ld+json" is:inline set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: 'Arsenal de IA — MSC Academy',
        description: 'Biblioteca de assets de IA prontos (templates, fluxos, hooks e superpowers) testados em produção, organizados do básico ao avançado, com o Método P.R.O.© para adaptar e criar os seus. Sem programar.',
        brand: { '@type': 'Organization', name: 'MSC Academy', sameAs: 'https://msccompany.com.br' },
        category: 'Digital product / AI toolkit',
        inLanguage: 'pt-BR',
        offers: { '@type': 'Offer', price: '97.00', priceCurrency: 'BRL', availability: 'https://schema.org/InStock', url: 'https://arsenal.msc-academy.com.br/' },
      })} />
    )}
    <slot name="head" />
  </head>
  <body class="bg-sand text-ink antialiased">
    {GTM_ID && (
      <noscript set:html={`<iframe src="https://www.googletagmanager.com/ns.html?id=${GTM_ID}" height="0" width="0" style="display:none;visibility:hidden"></iframe>`} />
    )}

    <slot />

    <!-- Banner de consentimento (LGPD) -->
    <div id="consent-banner" class="hidden fixed bottom-0 inset-x-0 z-50 p-4 sm:p-5 bg-sand-dark/97 backdrop-blur border-t border-ink/12">
      <div class="max-w-5xl mx-auto flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5 text-sm text-ink/80">
        <p class="flex-1">
          Usamos cookies para medir e melhorar sua experiência. Veja a
          <a href="/privacidade" class="underline text-indigo">Política de Privacidade</a>.
        </p>
        <div class="flex gap-2 shrink-0">
          <button id="consent-decline" class="px-4 py-2 rounded-lg border border-ink/15 text-ink hover:bg-ink/5">Recusar</button>
          <button id="consent-accept" class="px-4 py-2 rounded-lg bg-ink text-sand font-semibold hover:bg-ink/90">Aceitar</button>
        </div>
      </div>
    </div>

    <script>
      import { initPage } from '../lib/tracking';
      initPage();
    </script>
  </body>
</html>
