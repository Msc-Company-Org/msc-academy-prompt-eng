# ===== MSC Academy — Landing Prompt Engineering (Astro) =====
# Copie para .env (local) e configure no Vercel (Project Settings > Environment Variables).
# Variáveis PUBLIC_* são expostas ao browser; as demais ficam só no servidor.

# --- Tag Manager / Analytics (cliente) ---
PUBLIC_GTM_ID=GTM-P4P7R35C          # container real do Moisés (já é o default no código)
PUBLIC_GA_ID=                       # G-XXXXXXXX (só se NÃO usar GTM; opcional)
PUBLIC_FB_PIXEL_ID=                 # ID do Meta Pixel (opcional)

# --- Checkout Kiwify (cliente) ---
PUBLIC_KIWIFY_CHECKOUT_URL=         # ex.: https://pay.kiwify.com.br/XXXXXXX  (link do produto R$97)

# --- Captura de lead (servidor) ---
LEAD_WEBHOOK_URL=                   # webhook do n8n/Make/CRM p/ receber os leads da isca (opcional)

# --- Meta Conversions API (servidor) ---
FB_CAPI_TOKEN=                      # token da Conversions API (purchase/lead server-side)

# --- GA4 Measurement Protocol (servidor, p/ purchase via webhook Kiwify) ---
GA_ID=                              # G-XXXXXXXX (mesmo da property GA4)
GA_API_SECRET=                      # Measurement Protocol API secret (GA4 Admin > Data Streams)

# --- Webhook Kiwify (servidor) ---
KIWIFY_WEBHOOK_TOKEN=               # token/segredo p/ validar a assinatura do webhook Kiwify (painel Kiwify > Webhooks)

# --- Kiwify API / OAuth (servidor) — para integração programática (produtos, vendas) ---
KIWIFY_CLIENT_ID=                   # client_id da API Kiwify
KIWIFY_CLIENT_SECRET=               # client_secret da API Kiwify (NUNCA commitar)
KIWIFY_ACCOUNT_ID=                  # account_id Kiwify (header x-kiwify-account-id)

# --- Persistência do lead: Supabase (projeto msc-hub, online) ---
# Use a chave PUBLICÁVEL/anon (não a service_role). A tabela `leads` tem RLS com policy só de INSERT.
SUPABASE_URL=                       # https://SEUPROJETO.supabase.co
SUPABASE_KEY=                       # sb_publishable_xxx (chave publicável / anon)

# --- Entrega de e-mail: Resend (servidor) ---
RESEND_API_KEY=                     # re_xxx
RESEND_FROM=                        # ex.: Moisés (MSC Academy) <arsenal@send.msc-academy.com.br>  (domínio verificado no Resend)
RESEND_REPLY_TO=                    # e-mail real que recebe respostas (ex.: seu gmail)
